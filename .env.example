# Protocol Guardian — environment template.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# ─── Alchemy RPC (Sepolia) ─────────────────────────────────────────
# Sign up at https://dashboard.alchemy.com → Create App → Sepolia
ALCHEMY_WS_RPC=wss://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_HTTP_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ─── Anthropic Claude ──────────────────────────────────────────────
# Sign up at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Wallet keys ───────────────────────────────────────────────────
# Deployer: only used by `npm run deploy` to publish the contracts.
# Hot wallet: used by the running agent to call pause(). Holds GUARDIAN_ROLE.
# Use a fresh, low-balance Sepolia key for both — never your real wallet.
DEPLOYER_PRIVATE_KEY=
GUARDIAN_HOT_WALLET_PRIVATE_KEY=

# ─── Contract address ──────────────────────────────────────────────
# Populated automatically by `npm run deploy` (writes addresses.json).
# Override here if you want to point the agent at a different deployment.
GUARDIAN_CONTRACT_ADDRESS=

# ─── Watchlist ─────────────────────────────────────────────────────
# Comma-separated checksum addresses of protocols the agent watches.
# If unset, the agent reads addresses.json instead.
GUARDIAN_WATCHLIST=

# ─── Notification channels (optional) ──────────────────────────────
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ─── KeeperHub paid threat-intel (optional) ────────────────────────
# Without these set, the bridge degrades gracefully — the agent uses
# Claude's un-enriched verdict.
KEEPERHUB_API_KEY=
KEEPERHUB_TIMEOUT_S=10

# ─── AXL P2P swarm (optional) ──────────────────────────────────────
# When unset, the agent runs in single-node mode (no peer corroboration).
AXL_NODE_URL=http://localhost:7333

# ─── ENS (optional) ────────────────────────────────────────────────
# Only used by scripts/register_ens.mjs to register a Sepolia ENS name
# for the guardian wallet (improves dashboard identity display).
ENS_REGISTRANT_NAME=
